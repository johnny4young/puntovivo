{
  "name": "puntovivo",
  "version": "1.0.0",
  "description": "Modern POS Solutions System - Desktop Application",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "node ./scripts/dev-launcher.mjs desktop",
    "dev:web": "node ./scripts/dev-launcher.mjs web",
    "dev:server": "node ./scripts/dev-launcher.mjs server",
    "dev:fullstack": "node ./scripts/dev-launcher.mjs fullstack",
    "dev:all": "node ./scripts/dev-launcher.mjs desktop",
    "dev:desktop": "node ./scripts/dev-launcher.mjs desktop",
    "dev:desktop-only": "node ./scripts/dev-launcher.mjs desktop-only",
    "dev:stop": "node ./scripts/dev-launcher.mjs stop",
    "build": "npm run build --workspace=@puntovivo/web && npm run make --workspace=@puntovivo/desktop",
    "build:web": "npm run build --workspace=@puntovivo/web",
    "start": "npm run start --workspace=@puntovivo/desktop",
    "make": "npm run make --workspace=@puntovivo/desktop",
    "publish": "npm run publish --workspace=@puntovivo/desktop",
    "clean": "rm -rf node_modules apps/*/node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "concurrently": "^9.2.1",
    "prettier": "^3.4.2",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}

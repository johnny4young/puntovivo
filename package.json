{
  "name": "open-yojob",
  "version": "1.0.0",
  "description": "Modern POS Solutions System - Desktop Application",
  "private": true,
  "packageManager": "npm@10.8.2",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run start --workspace=@open-yojob/desktop",
    "build": "npm run make --workspace=@open-yojob/desktop",
    "start": "npm run start --workspace=@open-yojob/desktop",
    "make": "npm run make --workspace=@open-yojob/desktop",
    "publish": "npm run publish --workspace=@open-yojob/desktop",
    "clean": "rm -rf node_modules apps/*/node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

# NPM Configuration
# Ensure consistent behavior across environments

# Don't use package-lock if not already present
package-lock=true

# Use exact versions in package-lock
save-exact=false

# Audit level (info level shows all, but doesn't fail)
audit-level=moderate

# Engine strict (enforce node version from package.json)
engine-strict=false

# Log level
loglevel=error

# Explicitly run install scripts for this repo, even when the user has
# `ignore-scripts=true` in their global ~/.npmrc (a common security
# hardening). Puntovivo genuinely needs its postinstalls to run:
#
#   - `electron` → downloads the platform runtime (Electron.app /
#     electron.exe / electron) to node_modules/electron/dist/
#   - `better-sqlite3` → compiles the native SQLite binding for the host
#     Node ABI (later swapped to an Electron-ABI build by
#     scripts/ensure-native-runtime.mjs at app start)
#   - `argon2` → compiles its native password-hashing binding
#
# Without these, `require('electron')` throws "Electron failed to
# install correctly" and the embedded server crashes at boot with
# NODE_MODULE_VERSION mismatch errors.
ignore-scripts=false

# Run install scripts in the foreground and fail the install if any of
# them exit non-zero. Makes download/compile failures visible at install
# time instead of leaving a half-installed tree that breaks later.
foreground-scripts=true

# pnpm + npm workspace configuration.
# pnpm reads this .npmrc too; npm-only keys below are harmless to pnpm.

# Use exact versions in the lockfile? No — keep semver ranges.
save-exact=false

# Audit level (info level shows all, but doesn't fail).
audit-level=moderate

# Engine strict (enforce node version from package.json).
engine-strict=false

# Log level.
loglevel=error

# --- pnpm-specific ---------------------------------------------------
#
# node-linker=hoisted: lay out a flat node_modules (npm-style) instead of
# pnpm's default symlinked/isolated store. This is REQUIRED for this repo
# because the native-module tooling assumes a flat tree:
#   - electron-rebuild -m apps/desktop walks node_modules/ directly
#   - scripts/ensure-native-runtime.mjs swaps the compiled better-sqlite3
#     .node between an Electron-ABI and a Node-ABI build, keyed off
#     node_modules/.cache/puntovivo/native-binaries/ paths
#   - scripts/ensure-electron-binary.mjs probes node_modules/electron/dist
# Isolated linking would break every one of those path assumptions.
node-linker=hoisted

# shamefully-hoist: also hoist transitive deps to the root node_modules so
# packages that do non-declared requires (common in the native/build
# tooling chain) resolve the same way they did under npm's flat install.
shamefully-hoist=true

# Link local workspace packages by version match (npm-workspaces parity).
# pnpm 10+ defaults this to false; the workspace deps additionally use the
# workspace:* protocol, but keep this on so a plain version range still links.
link-workspace-packages=true

# Run lifecycle scripts for THIS repo's packages (electron/better-sqlite3/
# argon2 postinstalls). Dependency build scripts are separately allowlisted
# via pnpm.onlyBuiltDependencies in pnpm-workspace.yaml. Without this the
# embedded server crashes at boot with NODE_MODULE_VERSION mismatch and
# `require('electron')` throws "Electron failed to install correctly".
ignore-scripts=false

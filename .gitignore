# Audit evidence (screenshots, scratch notes) — kept on disk for the
# operator to review, never committed (binary churn).
.audit/
.artifacts/

# Claude Code + OpenAI Agents per-developer state. Skills live under
# `.claude/skills/` and `.agents/skills/` — both are intentionally
# kept OUT of git history because they evolve with each contributor's
# workflow and the OpenAI mirror has format-specific divergences
# (shorter description fields, separate openai.yaml manifests) that
# do not belong in shared repo history. New contributors bootstrap
# their own skill packs from a central registry, not from this repo.
.claude/skills/
.agents/skills/
.claude/worktrees/
.claude/scheduled_tasks.lock
.claude/settings.local.json
.claude/launch.json
.claude/preview.json

# Private planning and strategy — never publish execution queues, estimates,
# ticket maps, agent handoffs, or market notes. Public product truth belongs in
# docs/PROJECT-STATUS.md instead.
docs/planning/
docs/private/
docs/**/*.local.md
docs/ANALYSIS-*.md
docs/AUDIT-*.md
docs/HANDOFF-*.md
docs/*PLAN*.md
docs/*STRATEGY*.md
docs/*SPRINT*.md
docs/*follow-up work*.md
docs/*public status*.md
docs/*VISION*.md
docs/*MARKET*.md
docs/*VERTICAL*.md
docs/*CAPABILITY-AUDIT*.md

# Agent instructions + config — local only, never public (release prep)
AGENTS.md
CLAUDE.md
.claude/
.agents/

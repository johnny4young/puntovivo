{
  "name": "@puntovivo/shared",
  "version": "1.5.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./money": {
      "types": "./src/money.ts",
      "import": "./dist/money.js",
      "default": "./dist/money.js"
    },
    "./checkout-approval": {
      "types": "./src/checkout-approval.ts",
      "import": "./dist/checkout-approval.js",
      "default": "./dist/checkout-approval.js"
    },
    "./roles": {
      "types": "./src/roles.ts",
      "import": "./dist/roles.js",
      "default": "./dist/roles.js"
    },
    "./unit-math": {
      "types": "./src/unit-math.ts",
      "import": "./dist/unit-math.js",
      "default": "./dist/unit-math.js"
    },
    "./units": {
      "types": "./src/units.ts",
      "import": "./dist/units.js",
      "default": "./dist/units.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test --experimental-strip-types \"src/**/*.test.ts\"",
    "ci": "pnpm run typecheck && pnpm run test && pnpm run build",
    "clean": "node ../../scripts/clean-paths.mjs dist"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}

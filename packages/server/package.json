{
  "name": "@puntovivo/server",
  "version": "1.0.0",
  "description": "Puntovivo Backend Server - Fastify + Drizzle + SQLite",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "native:node": "node ../../scripts/ensure-native-runtime.mjs node",
    "native:rebuild:node": "node ./scripts/rebuild-better-sqlite3-node.mjs",
    "native:ensure:node": "node ../../scripts/ensure-native-runtime.mjs node",
    "build": "tsc && node ./scripts/copy-migrations.mjs",
    "typecheck": "tsc --noEmit",
    "dev": "npm run native:ensure:node && tsx watch src/standalone.ts",
    "start": "npm run native:ensure:node && node dist/standalone.js",
    "test": "npm run native:ensure:node && vitest run",
    "test:watch": "npm run native:ensure:node && vitest",
    "test:coverage": "npm run native:ensure:node && vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed:dev": "npm run native:ensure:node && tsx src/scripts/seed-dev.ts",
    "benchmark:invoice-ocr": "npm run native:ensure:node && tsx scripts/benchmark-invoice-ocr.ts",
    "benchmark:invoice-ocr:regen": "node scripts/generate-invoice-ocr-fixtures.mjs",
    "benchmark:payment-reconciliation": "npm run native:ensure:node && tsx scripts/benchmark-payment-reconciliation.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.72",
    "@ai-sdk/openai": "^3.0.0",
    "@aws-sdk/client-textract": "^3.1047.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@trpc/server": "^11.9.0",
    "ai": "^6.0.170",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.9.0",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.7.2",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "nanoid": "^5.1.9",
    "ollama-ai-provider-v2": "^3.5.0",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.1.7",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.1",
    "prettier": "^3.8.3",
    "tinyrainbow": "^3.1.0",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "electron": ">=30.0.0"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "pos",
    "fastify",
    "drizzle",
    "sqlite",
    "electron"
  ],
  "author": "Puntovivo",
  "license": "MIT"
}

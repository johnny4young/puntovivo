{
  "name": "@puntovivo/server",
  "version": "1.1.1",
  "description": "Puntovivo Backend Server - Fastify + Drizzle + SQLite",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "native:node": "node ../../scripts/ensure-native-runtime.mjs node",
    "native:rebuild:node": "node ./scripts/rebuild-better-sqlite3-node.mjs",
    "native:ensure:node": "node ../../scripts/ensure-native-runtime.mjs node",
    "build": "tsc && node ./scripts/copy-migrations.mjs",
    "typecheck": "tsc --noEmit",
    "dev": "pnpm run native:ensure:node && tsx watch src/standalone.ts",
    "start": "pnpm run native:ensure:node && node dist/standalone.js",
    "test": "pnpm run native:ensure:node && vitest run",
    "test:watch": "pnpm run native:ensure:node && vitest",
    "test:coverage": "pnpm run native:ensure:node && vitest run --coverage",
    "test:coverage:html": "pnpm run native:ensure:node && vitest run --coverage --coverage.reporter=text --coverage.reporter=text-summary --coverage.reporter=html --coverage.reporter=json --coverage.reporter=lcov",
    "lint": "eslint src --ext .ts",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "seed:dev": "pnpm run native:ensure:node && tsx src/scripts/seed-dev.ts",
    "benchmark:invoice-ocr": "pnpm run native:ensure:node && tsx scripts/benchmark-invoice-ocr.ts",
    "benchmark:invoice-ocr:regen": "node scripts/generate-invoice-ocr-fixtures.mjs",
    "benchmark:payment-reconciliation": "pnpm run native:ensure:node && tsx scripts/benchmark-payment-reconciliation.ts"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.81",
    "@ai-sdk/openai": "^3.0.68",
    "@ai-sdk/provider": "^3.0.10",
    "@ai-sdk/provider-utils": "^4.0.27",
    "@aws-sdk/client-textract": "^3.1064.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.1.0",
    "@fastify/rate-limit": "^11.0.0",
    "@sentry/node": "^10.57.0",
    "@trpc/server": "^11.17.0",
    "ai": "^6.0.198",
    "argon2": "^0.44.0",
    "better-sqlite3": "npm:better-sqlite3-multiple-ciphers@^12.10.0",
    "drizzle-orm": "^0.45.2",
    "fast-xml-parser": "^5.8.0",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "nanoid": "^5.1.11",
    "ollama-ai-provider-v2": "^3.5.1",
    "pino": "^10.3.1",
    "qrcode": "^1.5.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.1.8",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.4.1",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  },
  "peerDependencies": {
    "electron": ">=30.0.0"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "keywords": [
    "pos",
    "fastify",
    "drizzle",
    "sqlite",
    "electron"
  ],
  "author": {
    "name": "johnny4young",
    "email": "asesordeprogramacion@gmail.com"
  },
  "license": "MIT",
  "private": true
}

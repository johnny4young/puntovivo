{
  "name": "@open-yojob/server",
  "version": "1.0.0",
  "description": "Open Yojob Backend Server - Fastify + Drizzle + SQLite",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "native:node": "node ../../scripts/ensure-native-runtime.mjs node",
    "native:rebuild:node": "node ./scripts/rebuild-better-sqlite3-node.mjs",
    "native:ensure:node": "node ../../scripts/ensure-native-runtime.mjs node",
    "build": "tsc",
    "dev": "npm run native:ensure:node && tsx watch src/standalone.ts",
    "start": "npm run native:ensure:node && node dist/standalone.js",
    "test": "npm run native:ensure:node && vitest run",
    "test:watch": "npm run native:ensure:node && vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@trpc/server": "^11.9.0",
    "argon2": "^0.44.0",
    "better-sqlite3": "^12.0.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "nanoid": "^5.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "prettier": "^3.4.2",
    "tinyrainbow": "^1.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "electron": ">=30.0.0"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "pos",
    "fastify",
    "drizzle",
    "sqlite",
    "electron"
  ],
  "author": "Open Yojob",
  "license": "MIT"
}

{
  "name": "@open-yojob/server",
  "version": "1.0.0",
  "description": "Open Yojob Backend Server - Fastify + Drizzle + SQLite",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/standalone.ts",
    "start": "node dist/standalone.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --check \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@trpc/server": "^11.9.0",
    "argon2": "^0.41.1",
    "better-sqlite3": "^12.0.0",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "nanoid": "^5.0.9",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "drizzle-kit": "^0.30.1",
    "eslint": "^10.0.3",
    "prettier": "^3.4.2",
    "tinyrainbow": "^1.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "electron": ">=30.0.0"
  },
  "peerDependenciesMeta": {
    "electron": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "pos",
    "fastify",
    "drizzle",
    "sqlite",
    "electron"
  ],
  "author": "Open Yojob",
  "license": "MIT"
}

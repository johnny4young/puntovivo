# =============================================================================
# Puntovivo - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# `.env` at the repo root is auto-loaded by the server via Node 22's
# `process.loadEnvFile()` (see `packages/server/src/loadEnv.ts`). No
# third-party dotenv dependency. CI / production deployments still
# inject env vars through their own mechanism — the auto-load is
# best-effort and silently no-ops when no `.env` is present.
# Inline `EXPORT=value npm run dev:server` still works and overrides
# `.env` (env vars set before the loader runs are preserved).

# ====================
# Server Configuration
# ====================

# Server port (default: 8090)
PORT=8090
APP_PORT=8090

# Server host
# - 127.0.0.1 = localhost only (recommended for development)
# - 0.0.0.0 = all network interfaces (for production/Docker)
HOST=127.0.0.1

# Database path (relative to packages/server or absolute)
# Default: ./data/local.db
# DATABASE_URL=./data/local.db

# SQLite writer-lock wait in milliseconds. Default is 5000; raise only
# for high-contention dev/test harnesses that intentionally share one DB.
# PUNTOVIVO_SQLITE_BUSY_TIMEOUT_MS=15000

# JWT Secret for authentication
# Auto-generated if not set, but recommended to set for production
# Generate with: openssl rand -base64 32
# JWT_SECRET=your-secret-key-here

# Enable verbose logging (default: false in production, true in development)
# VERBOSE=true

# Pino log level (trace|debug|info|warn|error|fatal). Defaults to
# `info` in production and `debug` in development. Override when
# debugging a specific subsystem; `trace` is very chatty.
# PUNTOVIVO_LOG_LEVEL=debug

# Runtime environment marker. The seed-dev script and the seeded-
# admin code refuse to run when this resolves to `production` to
# prevent accidental fixture seeding in a real DB. Defaults to
# `production` when NODE_ENV=production, else `development`.
# PUNTOVIVO_RUNTIME_ENV=development

# Global Fastify rate-limit ceiling (requests per minute, per IP).
# Default 100 covers a small storefront cleanly. Raise it for
# high-volume single-NAT deployments. Auth-bucket limits
# (loginRateLimit) live separately and are not affected.
# PUNTOVIVO_GLOBAL_RATE_LIMIT_MAX=100

# Override the default development admin password (seeded on first
# boot of a fresh DB). Read once at seed time only — changing this
# after the DB exists has no effect on the existing user. Default
# is `Admin123!Dev`. See docs/DEV-SEED.md.
# PUNTOVIVO_DEV_ADMIN_PASSWORD=your-dev-password

# ====================
# AI Configuration ( + )
# ====================

# Anthropic API key. Backs the Vercel AI SDK provider for the
# admin co-pilot, completeTest smoke, and (when  lands)
# semantic search. Get one from https://console.anthropic.com/ →
# API Keys. The Settings → AI card flips to "Provider configured"
# once this is present. Without the key set, calls routed to
# Anthropic fail with `AI_PROVIDER_ERROR` and the audit-log row
# records the failure with cost_usd=0.
# Per-tenant key storage is deferred — today the env var is the
# single source of truth for the embedded server.
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key. Backs the OpenAI chat provider (default model
# gpt-4.1-mini). Activated by  as a fallback for Anthropic
# when billing reconciliation drags. Get one from
# https://platform.openai.com/api-keys. When both ANTHROPIC_API_KEY
# and OPENAI_API_KEY are present, the active provider is whichever
# one the operator selected on the Settings → AI card. Embeddings
# (text-embedding-3-small / -3-large) land later with .
# OPENAI_API_KEY=sk-...

# Ollama base URL. Optional override for the local-LLM provider
# activated in . Default is `http://localhost:11434`, which
# matches the Ollama daemon's out-of-the-box bind. Point this at a
# remote machine (e.g. `https://gpu.lan:11434`) when the device runs
# headless and Ollama lives on a separate GPU host. No API key is
# required — Ollama serves locally over HTTP. The provider is
# `isConfigured() === true` whether or not this var is set; the first
# real call surfaces a connection error if the daemon is offline.
# Backs both chat (co-pilot, completeTest) and vision (invoice OCR,
# line-to-product matcher) once the admin picks `ollama` in the
# Settings → AI card and pulls a model (e.g. `ollama pull llama3.2`
# for chat, `ollama pull llava` for vision).
# OLLAMA_BASE_URL=http://localhost:11434

# ====================
# Auto-update (Electron)
# ====================

# Auto-update configuration (optional, defaults to true)
# AUTO_UPDATE=true

# Auto-update polling interval. Accepts strings parsed by
# electron-updater (e.g. `1 hour`, `30 minutes`, `6 hours`).
# Default: `1 hour`.
# AUTO_UPDATE_INTERVAL=1 hour

# ====================
# Desktop Development (Electron)
# ====================

# URL the Electron main process loads in the renderer during
# development. Defaults to `http://localhost:3000` (the Vite dev
# server). Override only when running Vite on a non-default port or
# proxying through another host.
# WEB_DEV_SERVER_URL=http://localhost:3000

# Open Chromium DevTools automatically when the desktop dev shell
# starts. Set to `true` for renderer debugging; defaults to off.
# PUNTOVIVO_OPEN_DEVTOOLS=true

# ====================
# Web Development
# ====================

# Web dev server port (for docker-compose with --profile development)
WEB_DEV_PORT=3000

# API URL for web frontend (see apps/web/.env.example)
VITE_API_URL=http://localhost:8090

# ====================
# Seed scripts (npm run seed:dev)
# ====================
#
# `SEED_PRESET`, `SEED_RESET`, and `SEED_TARGET` configure the
# fixture seeder; they are inputs to `npm run seed:dev` and are not
# read by the running server. Full reference + recipes in
# docs/DEV-SEED.md. Example usage:
#
# SEED_RESET=1 SEED_PRESET=demo-co npm run seed:dev

# ====================
# Legacy Configuration (for migration scripts only)
# ====================

# Backup Schedule (cron format)
# BACKUP_SCHEDULE=0 2 * * *

# Migration admin credentials (for scripts/migration/ tool)
# PB_ADMIN_EMAIL=admin@example.com
# PB_ADMIN_PASSWORD=your-secure-password

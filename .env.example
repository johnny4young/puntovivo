# =============================================================================
# Open Yojob - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values

# ====================
# Server Configuration
# ====================

# Server port (default: 8090)
PORT=8090
APP_PORT=8090

# Server host
# - 127.0.0.1 = localhost only (recommended for development)
# - 0.0.0.0 = all network interfaces (for production/Docker)
HOST=127.0.0.1

# Database path (relative to packages/server or absolute)
# Default: ./data/local.db
# DATABASE_URL=./data/local.db

# JWT Secret for authentication
# Auto-generated if not set, but recommended to set for production
# Generate with: openssl rand -base64 32
# JWT_SECRET=your-secret-key-here

# Enable verbose logging (default: false in production, true in development)
# VERBOSE=true

# Auto-update configuration (optional, defaults to true)
# AUTO_UPDATE=true

# ====================
# Web Development
# ====================

# Web dev server port (for docker-compose with --profile development)
WEB_DEV_PORT=3000

# API URL for web frontend (see apps/web/.env.example)
VITE_API_URL=http://localhost:8090

# ====================
# Legacy Configuration (PocketBase - if migrating from old setup)
# ====================

# PocketBase encryption key (only if using PocketBase)
# PB_ENCRYPTION_KEY=your-32-character-encryption-key

# Backup Schedule (cron format)
# BACKUP_SCHEDULE=0 2 * * *

# Migration admin credentials (for migration scripts)
# PB_ADMIN_EMAIL=admin@example.com
# PB_ADMIN_PASSWORD=your-secure-password

# Web App Configuration
# Copy this file to .env and customize as needed

# API URL for backend server
# This controls where the tRPC client connects to
# Default: http://localhost:8090
# Production: https://your-api-domain.com
VITE_API_URL=http://localhost:8090

# Enable offline support
# Default: true
VITE_ENABLE_OFFLINE=true

# Sync interval in milliseconds
# How often to sync with server when online
# Default: 30000 (30 seconds)
VITE_SYNC_INTERVAL=30000

# Application name
# Displayed in UI
VITE_APP_NAME=Puntovivo

# Web Vitals RUM sampling rate (0.0 to 1.0)
# Fraction of page loads that report Core Web Vitals (LCP / CLS / INP / TTFB / FCP).
# Default: 0.1 in production, 1.0 in dev. Set to 0 to disable reporting.
VITE_WEB_VITALS_SAMPLE_RATE=0.1

# Note: Changes to VITE_* variables require rebuilding the web app
# Run: npm run build:web

{
  "name": "@open-yojob/desktop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Open Yojob Desktop Application - POS Solutions",
  "main": ".vite/build/index.cjs",
  "scripts": {
    "start": "electron-forge start",
    "dev": "npm run rebuild && electron-forge start",
    "dev:debug": "npm run rebuild && ELECTRON_ENABLE_LOGGING=1 electron-forge start -- --inspect=5858",
    "dev:debug-brk": "npm run rebuild && ELECTRON_ENABLE_LOGGING=1 electron-forge start -- --inspect-brk=5858",
    "dev:server": "DEBUG=fastify:* npm run dev",
    "rebuild": "electron-rebuild -f -v 40.1.0",
    "package": "npm run build --workspace=@open-yojob/web && electron-forge package",
    "make": "npm run build --workspace=@open-yojob/web && electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint .",
    "format": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .vite out node_modules",
    "clean:cache": "rm -rf .vite && npm run dev"
  },
  "keywords": [
    "pos",
    "point-of-sale",
    "electron",
    "desktop",
    "retail"
  ],
  "author": {
    "name": "Johnny4Young",
    "email": "johnny4young@github.com"
  },
  "license": "MIT",
  "dependencies": {
    "@electron/rebuild": "^4.0.3",
    "@open-yojob/server": "1.0.0",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-table": "^8.20.6",
    "@tanstack/react-virtual": "^3.11.2",
    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "lucide-react": "^0.563.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.54.2",
    "react-router-dom": "^7.13.0",
    "tailwind-merge": "^3.0.0",
    "update-electron-app": "^3.1.2",
    "exceljs": "^4.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^9.39.2",
    "@tailwindcss/vite": "^4.0.0",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "electron": "^40.1.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}

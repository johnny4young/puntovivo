{
  "name": "@puntovivo/desktop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Puntovivo Desktop Application - POS Solutions",
  "main": ".vite/build/index.cjs",
  "scripts": {
    "prepare:server": "npm run build --workspace=@puntovivo/server",
    "native:ensure:electron": "node ../../scripts/ensure-native-runtime.mjs electron",
    "electron:ensure:binary": "node ../../scripts/ensure-electron-binary.mjs",
    "build:main": "node ../../scripts/build-electron-main.mjs",
    "preflight:desktop": "npm run prepare:server && npm run electron:ensure:binary && npm run native:ensure:electron",
    "dev:desktop": "npm run preflight:desktop && electron-forge start",
    "dev:desktop:debug": "npm run preflight:desktop && ELECTRON_ENABLE_LOGGING=1 electron-forge start -- --inspect=5858",
    "dev:desktop:debug-brk": "npm run preflight:desktop && ELECTRON_ENABLE_LOGGING=1 electron-forge start -- --inspect-brk=5858",
    "dev:desktop:server-logs": "DEBUG=fastify:* npm run dev:desktop",
    "rebuild": "electron-rebuild -f -v 41.2.2",
    "package:desktop": "npm run prepare:server && npm run electron:ensure:binary && npm run build --workspace=@puntovivo/web && electron-forge package",
    "make:desktop": "npm run prepare:server && npm run electron:ensure:binary && npm run build --workspace=@puntovivo/web && electron-forge make",
    "publish:desktop": "electron-forge publish",
    "lint": "eslint .",
    "test": "node --test --experimental-strip-types \"src/main/__tests__/**/*.test.ts\"",
    "format": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .vite out node_modules",
    "clean:cache": "rm -rf .vite && npm run dev:desktop"
  },
  "keywords": [
    "pos",
    "point-of-sale",
    "electron",
    "desktop",
    "retail"
  ],
  "author": {
    "name": "Johnny4Young",
    "email": "johnny4young@github.com"
  },
  "license": "MIT",
  "dependencies": {
    "@electron/rebuild": "^4.0.4",
    "@puntovivo/server": "1.0.0",
    "@tanstack/react-query": "^5.100.3",
    "@tanstack/react-table": "^8.20.6",
    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "exceljs": "^4.4.0",
    "jspdf": "^4.1.0",
    "jspdf-autotable": "^5.0.7",
    "jszip": "^3.10.1",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.73.1",
    "react-router-dom": "^7.14.2",
    "tailwind-merge": "^3.0.0",
    "update-electron-app": "^3.1.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-fuses": "^7.11.1",
    "@electron-forge/plugin-vite": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "@electron/fuses": "^1.8.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.2.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "concurrently": "^9.2.1",
    "electron": "^41.2.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}

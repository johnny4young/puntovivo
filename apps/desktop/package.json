{
  "name": "@puntovivo/desktop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Puntovivo Desktop Application - POS Solutions",
  "main": ".vite/build/index.cjs",
  "scripts": {
    "prepare:server": "pnpm --filter @puntovivo/server run build",
    "native:ensure:electron": "node ../../scripts/ensure-native-runtime.mjs electron",
    "native:ensure:node": "node ../../scripts/ensure-native-runtime.mjs node",
    "electron:ensure:binary": "node ../../scripts/ensure-electron-binary.mjs",
    "electron:ensure:migrations": "node ../../scripts/ensure-migrations-bundled.mjs",
    "build:main": "node ../../scripts/build-electron-main.mjs",
    "preflight:desktop": "pnpm run prepare:server && pnpm run electron:ensure:migrations && pnpm run electron:ensure:binary && pnpm run native:ensure:electron",
    "dev:desktop": "pnpm run preflight:desktop && electron-forge start",
    "dev:desktop:debug": "pnpm run preflight:desktop && ELECTRON_ENABLE_LOGGING=1 electron-forge start -- --inspect=5858",
    "dev:desktop:debug-brk": "pnpm run preflight:desktop && ELECTRON_ENABLE_LOGGING=1 electron-forge start -- --inspect-brk=5858",
    "dev:desktop:server-logs": "DEBUG=fastify:* pnpm run dev:desktop",
    "rebuild": "electron-rebuild -f",
    "package:desktop": "pnpm run prepare:server && pnpm run electron:ensure:migrations && pnpm run electron:ensure:binary && pnpm --filter @puntovivo/web run build && electron-forge package",
    "make:desktop": "pnpm run prepare:server && pnpm run electron:ensure:migrations && pnpm run electron:ensure:binary && pnpm --filter @puntovivo/web run build && electron-forge make",
    "publish:desktop": "electron-forge publish",
    "lint": "eslint .",
    "test": "pnpm run native:ensure:node && node --test --experimental-strip-types \"src/main/**/*.test.ts\"",
    "format": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "format:fix": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .vite out node_modules",
    "clean:cache": "rm -rf .vite && pnpm run dev:desktop"
  },
  "keywords": [
    "pos",
    "point-of-sale",
    "electron",
    "desktop",
    "retail"
  ],
  "author": {
    "name": "Johnny4Young",
    "email": "johnny4young@github.com"
  },
  "license": "MIT",
  "dependencies": {
    "@electron/rebuild": "^4.0.4",
    "@puntovivo/server": "workspace:*",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-table": "^8.21.3",
    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "exceljs": "^4.4.0",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.8",
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.76.1",
    "react-router-dom": "^7.15.1",
    "sanitize-html": "^2.17.4",
    "tailwind-merge": "^3.6.0",
    "update-electron-app": "^3.2.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron-forge/publisher-github": "^7.11.2",
    "@electron/fuses": "^2.1.1",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^9.2.1",
    "electron": "^41.7.1",
    "eslint": "^10.4.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
